PORT=5005
CLIENT_URL=http://localhost:5173
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-a-different-long-random-secret

STREAM_API_KEY=your-stream-api-key
STREAM_API_SECRET=your-stream-api-secret

# Firebase Admin: use either FIREBASE_SERVICE_ACCOUNT_JSON or the split fields below.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# SMTP is optional in development. Without it, verification/reset links are logged.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PinWell <no-reply@pinwell.app>
